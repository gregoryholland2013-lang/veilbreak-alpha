{
  "name": "Friendship",
  "type": "object",
  "properties": {
    "requester_email": {
      "type": "string",
      "description": "Email of the user who sent the request"
    },
    "recipient_email": {
      "type": "string",
      "description": "Email of the user who received the request"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "rejected"
      ],
      "default": "pending"
    },
    "accepted_at": {
      "type": "string",
      "description": "ISO date when friendship was accepted"
    },
    "last_cheer_by_requester": {
      "type": "string",
      "description": "ISO date of last cheer from requester"
    },
    "last_cheer_by_recipient": {
      "type": "string",
      "description": "ISO date of last cheer from recipient"
    }
  },
  "required": [
    "requester_email",
    "recipient_email"
  ]
}